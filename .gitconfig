[user]
	name = Andrii Serhiienko
	email = andrey.sergienko@gmail.com

[github]
  user = fycth

[commit]
  template = ~/.gitmessage

[alias]
  graph = log --graph
  last = log -n 10
  discard = checkout -- .
  rmtag = "!sh -c 'git tag -d $1; git push origin :refs/tags/$1'"

  changelog = !sh "$HOME/dotfiles/git-extras/git-changelog.sh"

[push]
  default = current

[color]
  ui = true

[core]
  editor = vim
	excludesfile = ~/.gitignore_global
	pager = diff-so-fancy | less --tabs=4 -RFX

[format]
  pretty = %Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset
  graph = true

[advice]
  statusHints = false

[log]
  abbrevCommit = true

[mergetool]
	keepBackup = false
[init]
	templatedir = ~/.git_template
	defaultBranch = main
[ghi]
	token = !security find-internet-password -a fycth -s github.com -l 'ghi token' -w
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
#[url "git@github.com:"]
#	insteadOf = https://github.com/
# this option below is a workaround for a bug in Rust's Cargo
[net]
	git-fetch-with-cli = true
[merge]
	ff = false
[interactive]
	diffFilter = diff-so-fancy --patch
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[color "diff"]
	meta = 11
	frag = magenta bold
	func = 146 bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
